<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bravoo — Ton coach personnel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    /* ========================================
       RESET & BASE
       ======================================== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      /* BRANDING BRAVOO — IDENTIQUE AU SITE */
      --bg-page: #121212;
      --bg-surface: #181818;
      --bg-surface-hover: #282828;
      --primary: #1DB954;
      --primary-light: #1ED760;
      --primary-dark: #169C46;
      --accent: #F5C518;
      --text-primary: #FFFFFF;
      --text-secondary: #B3B3B3;
      --text-muted: #727272;
      --border-subtle: rgba(255, 255, 255, 0.06);
      --green: #22c55e;
      --red: #ef4444;
      --font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-family);
      background: var(--bg-page);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100dvh;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0;
      position: relative;
      overflow: hidden;
    }

    /* Grain texture globale */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      opacity: 0.02;
      z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='2.5' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' fill='%23FFF'/%3E%3C/svg%3E");
    }

    /* Particules flottantes en background */
    .hero-particles {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .particle {
      position: absolute;
      width: 3px;
      height: 3px;
      background: var(--primary);
      border-radius: 50%;
      opacity: 0;
      box-shadow: 0 0 8px rgba(29, 185, 84, 0.6);
      animation: particleFloat 12s ease-in-out infinite;
    }

    @keyframes particleFloat {
      0% {
        transform: translate(0, 100vh) scale(0);
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        transform: translate(var(--tx), -100px) scale(1);
        opacity: 0;
      }
    }

    .particle:nth-child(1) { left: 10%; animation-delay: 0s; --tx: 20px; }
    .particle:nth-child(2) { left: 20%; animation-delay: 1.5s; --tx: -30px; }
    .particle:nth-child(3) { left: 30%; animation-delay: 3s; --tx: 40px; }
    .particle:nth-child(4) { left: 40%; animation-delay: 4.5s; --tx: -20px; }
    .particle:nth-child(5) { left: 50%; animation-delay: 6s; --tx: 30px; }
    .particle:nth-child(6) { left: 60%; animation-delay: 7.5s; --tx: -40px; }
    .particle:nth-child(7) { left: 70%; animation-delay: 9s; --tx: 25px; }
    .particle:nth-child(8) { left: 80%; animation-delay: 10.5s; --tx: -35px; }

    /* ========================================
       LOGO
       ======================================== */
    .logo-bar {
      width: 100%;
      max-width: 460px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 16px 8px;
      position: relative;
      z-index: 10;
      flex-shrink: 0;
    }

    .logo {
      font-size: 28px;
      font-weight: 800;
      text-decoration: none;
      color: var(--text-primary);
      overflow: visible;
    }

    .logo-brav {
      color: var(--text-primary);
    }

    .logo-oo {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative;
      display: inline-block;
      font-size: 34px;
      vertical-align: baseline;
      line-height: 1;
      letter-spacing: -2px;
      font-weight: 900;
      overflow: visible;
      padding-right: 8px;
      padding-top: 14px;
    }

    .logo-oo::after {
      content: '★';
      position: absolute;
      top: -12px;
      right: -4px;
      font-size: 14px;
      -webkit-text-fill-color: var(--accent);
      background: none;
      -webkit-background-clip: unset;
      line-height: 1;
      filter: drop-shadow(0 0 4px rgba(245, 197, 24, 0.5));
    }

    /* ========================================
       PROGRESS BAR
       ======================================== */
    .progress-bar-bg {
      width: 100%;
      max-width: 460px;
      height: 6px;
      border-radius: 3px;
      background: rgba(255, 255, 255, 0.1);
      margin: 0 16px 12px 16px;
      overflow: hidden;
      position: relative;
      z-index: 10;
      flex-shrink: 0;
    }

    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary), var(--primary-light), var(--accent));
      background-size: 200% 100%;
      border-radius: 3px;
      transition: width 0.5s ease;
      animation: shimmer 2s ease-in-out infinite;
    }

    @keyframes shimmer {
      0%, 100% {
        background-position: 0% center;
      }
      50% {
        background-position: 100% center;
      }
    }

    /* ========================================
       CARD
       ======================================== */
    .card {
      width: 100%;
      max-width: 460px;
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: 28px 28px 0 0;
      box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.5);
      position: relative;
      z-index: 10;
      transition: opacity 0.25s ease, transform 0.25s ease;
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      margin: 0 16px 0 16px;
    }

    .card.fade-in {
      opacity: 1;
      transform: translateY(0);
    }

    .card.fade-out {
      opacity: 0;
      transform: translateY(12px);
    }

    .card-content {
      flex: 1;
      overflow-y: auto;
      padding: 24px 20px 16px 20px;
      -webkit-overflow-scrolling: touch;
    }

    .card-action {
      padding: 16px 20px 20px 20px;
      background: linear-gradient(to bottom, transparent 0%, var(--bg-surface) 20%);
      flex-shrink: 0;
    }

    .step-label {
      font-size: 12px;
      font-weight: 800;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }

    .heading {
      font-size: 22px;
      font-weight: 900;
      color: var(--text-primary);
      line-height: 1.2;
      margin: 0 0 20px;
    }

    .subtitle {
      color: var(--text-secondary);
      font-size: 14px;
      margin: 0 0 16px;
      line-height: 1.6;
    }

    /* ========================================
       INPUT
       ======================================== */
    .input {
      width: 100%;
      padding: 14px 16px;
      border-radius: 16px;
      border: 2px solid var(--border-subtle);
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      background: var(--bg-page);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      box-sizing: border-box;
    }

    .input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(29, 185, 84, 0.1);
    }

    .input-wrapper {
      position: relative;
    }

    .input-suffix {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
      font-weight: 700;
      font-size: 16px;
      pointer-events: none;
    }

    /* ========================================
       BUTTON
       ======================================== */
    .btn {
      width: 100%;
      padding: 15px 24px;
      border-radius: 50px;
      border: none;
      background: var(--primary);
      color: var(--text-primary);
      font-size: 16px;
      font-weight: 900;
      cursor: pointer;
      margin-top: 16px;
      box-shadow: 0 8px 24px rgba(29, 185, 84, 0.3);
      transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
      font-family: var(--font-family);
      animation: gentleGlow 3s ease-in-out infinite;
    }

    @keyframes gentleGlow {
      0%, 100% {
        box-shadow: 0 8px 24px rgba(29, 185, 84, 0.3);
      }
      50% {
        box-shadow: 0 8px 32px rgba(29, 185, 84, 0.4);
      }
    }

    .btn:hover:not(:disabled) {
      background: var(--primary-light);
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(29, 185, 84, 0.4);
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      box-shadow: none;
      animation: none;
    }

    /* ========================================
       CHIPS / CARDS
       ======================================== */
    .chips-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .chip {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-radius: 16px;
      border: 2px solid rgba(255, 255, 255, 0.15);
      background: var(--bg-surface);
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      font-weight: 700;
      font-size: 15px;
      color: var(--text-primary);
      opacity: 0;
      transform: translateY(20px) scale(0.95);
      animation: bounceIn 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55) forwards;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .chip:nth-child(1) { animation-delay: 0s; }
    .chip:nth-child(2) { animation-delay: 0.05s; }
    .chip:nth-child(3) { animation-delay: 0.1s; }
    .chip:nth-child(4) { animation-delay: 0.15s; }
    .chip:nth-child(5) { animation-delay: 0.2s; }
    .chip:nth-child(6) { animation-delay: 0.25s; }
    .chip:nth-child(7) { animation-delay: 0.3s; }
    .chip:nth-child(8) { animation-delay: 0.35s; }
    .chip:nth-child(9) { animation-delay: 0.4s; }
    .chip:nth-child(10) { animation-delay: 0.45s; }
    .chip:nth-child(11) { animation-delay: 0.5s; }
    .chip:nth-child(12) { animation-delay: 0.55s; }

    @keyframes bounceIn {
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .chip:hover {
      transform: translateY(-2px) scale(1.02);
      border-color: var(--primary);
      box-shadow: 0 8px 24px rgba(29, 185, 84, 0.2);
    }

    .chip.selected {
      border-color: var(--primary);
      background: rgba(29, 185, 84, 0.1);
      box-shadow: 0 0 0 4px rgba(29, 185, 84, 0.1);
    }

    .chip .emoji {
      font-size: 18px;
    }

    .chip .checkmark {
      margin-left: auto;
      color: var(--primary);
      font-weight: 900;
    }

    /* ========================================
       OBJECTIF CARDS
       ======================================== */
    .objectif-card {
      padding: 16px;
      border-radius: 16px;
      border: 2px solid rgba(255, 255, 255, 0.15);
      background: var(--bg-surface);
      cursor: pointer;
      transition: all 0.3s ease;
      text-align: left;
      margin-bottom: 10px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    .objectif-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent);
      box-shadow: 0 8px 24px rgba(245, 197, 24, 0.2);
    }

    .objectif-card.selected {
      border-color: var(--accent);
      background: rgba(245, 197, 24, 0.1);
      box-shadow: 0 0 0 4px rgba(245, 197, 24, 0.1);
    }

    .objectif-card .label {
      font-weight: 800;
      font-size: 15px;
      color: var(--text-primary);
    }

    .objectif-card .value {
      font-size: 24px;
      font-weight: 900;
      color: var(--accent);
      margin-top: 4px;
    }

    /* ========================================
       LOADING
       ======================================== */
    .loading-container {
      text-align: center;
      padding: 32px 0;
    }

    .spinner {
      width: 56px;
      height: 56px;
      border: 4px solid var(--border-subtle);
      border-top-color: var(--primary);
      border-radius: 50%;
      margin: 0 auto 24px;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    .loading-msg {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.6;
      min-height: 60px;
      padding: 0 8px;
      animation: fadeInUp 0.5s ease-out;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ========================================
       QUIZ
       ======================================== */
    .quiz-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    .quiz-badge {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-primary);
      background: var(--primary);
      padding: 4px 10px;
      border-radius: 999px;
    }

    .quiz-choices {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .quiz-choice {
      padding: 13px 16px;
      border-radius: 14px;
      border: 2px solid var(--border-subtle);
      background: var(--bg-surface);
      cursor: pointer;
      transition: all 0.2s;
      font-weight: 600;
      font-size: 14px;
      color: var(--text-primary);
      text-align: left;
      display: flex;
      align-items: center;
    }

    .quiz-choice:hover {
      border-color: var(--primary);
      transform: translateX(4px);
    }

    .quiz-choice.selected {
      border-color: var(--primary);
      background: rgba(29, 185, 84, 0.1);
    }

    .quiz-choice.correct {
      border-color: var(--green);
      background: #f0fdf4;
    }

    .quiz-choice.wrong {
      border-color: var(--red);
      background: #fef2f2;
    }

    .quiz-choice .letter {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 8px;
      background: rgba(29, 185, 84, 0.1);
      color: var(--primary);
      font-size: 12px;
      font-weight: 900;
      margin-right: 10px;
      flex-shrink: 0;
    }

    .quiz-choice.correct .letter {
      background: var(--green);
      color: var(--text-primary);
    }

    .quiz-choice.wrong .letter {
      background: var(--red);
      color: var(--text-primary);
    }

    .quiz-explanation {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.5;
      animation: fadeInUp 0.3s ease-out;
    }

    .quiz-explanation.correct {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
    }

    .quiz-explanation.wrong {
      background: #fef2f2;
      border: 1px solid #fecaca;
    }

    .quiz-progress {
      margin-top: 20px;
      height: 4px;
      border-radius: 2px;
      background: var(--border-subtle);
      overflow: hidden;
    }

    .quiz-progress-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 2px;
      transition: width 0.4s ease;
    }

    /* ========================================
       RECAP APP
       ======================================== */
    .recap-score {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(29, 185, 84, 0.1);
      margin-bottom: 16px;
    }

    .recap-score .percent {
      font-size: 28px;
      font-weight: 900;
      color: var(--primary);
    }

    .recap-score .label {
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .recap-bullets {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 8px;
    }

    .recap-bullet {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .recap-bullet .icon {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }

    .recap-bullet .icon.blue {
      background: rgba(29, 185, 84, 0.1);
    }

    .recap-bullet .icon.yellow {
      background: rgba(245, 197, 24, 0.1);
    }

    .recap-bullet .icon.green {
      background: #f0fdf4;
    }

    .recap-bullet .text .title {
      font-weight: 800;
      font-size: 14px;
      color: var(--text-primary);
      margin-bottom: 2px;
    }

    .recap-bullet .text .desc {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    /* ========================================
       PAYWALL
       ======================================== */
    .paywall-hero {
      text-align: center;
      margin-bottom: 20px;
    }

    .paywall-hero .emoji {
      font-size: 48px;
      margin-bottom: 12px;
      animation: bounceIn 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55);
    }

    .paywall-hero .title {
      font-size: 24px;
      font-weight: 900;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .paywall-hero .subtitle {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .paywall-summary {
      padding: 16px;
      border-radius: 16px;
      background: rgba(29, 185, 84, 0.05);
      border: 1px solid var(--border-subtle);
      margin-bottom: 16px;
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .paywall-summary strong {
      color: var(--text-primary);
      font-weight: 700;
    }

    .paywall-features {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }

    .paywall-feature {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .paywall-feature .icon {
      font-size: 18px;
    }

    .paywall-stars {
      text-align: center;
      font-size: 20px;
      color: var(--accent);
      margin-bottom: 16px;
      filter: drop-shadow(0 0 4px rgba(245, 197, 24, 0.5));
    }

    .paywall-badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--red), #ff6b6b);
      color: var(--text-primary);
      font-size: 12px;
      font-weight: 800;
      padding: 6px 12px;
      border-radius: 999px;
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }

    .paywall-places {
      text-align: center;
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 12px;
    }

    .paywall-places strong {
      color: var(--red);
      font-weight: 800;
    }

    .paywall-pricing {
      text-align: center;
      margin-bottom: 16px;
    }

    .paywall-old-price {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-muted);
      text-decoration: line-through;
      margin-bottom: 4px;
      animation: strikethrough 1s ease-out forwards;
    }

    @keyframes strikethrough {
      from {
        opacity: 1;
      }
      to {
        opacity: 0.6;
      }
    }

    .paywall-new-price {
      font-size: 48px;
      font-weight: 900;
      color: var(--primary);
      line-height: 1;
      margin-bottom: 4px;
      animation: priceGlow 2s ease-in-out infinite;
    }

    @keyframes priceGlow {
      0%, 100% {
        text-shadow: 0 0 20px rgba(29, 185, 84, 0.5);
      }
      50% {
        text-shadow: 0 0 30px rgba(29, 185, 84, 0.7);
      }
    }

    .paywall-discount {
      display: inline-block;
      background: var(--accent);
      color: var(--bg-page);
      font-size: 14px;
      font-weight: 900;
      padding: 4px 12px;
      border-radius: 999px;
      margin-bottom: 16px;
    }

    .paywall-timer {
      text-align: center;
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 16px;
    }

    .paywall-timer .time {
      font-size: 20px;
      font-weight: 900;
      color: var(--red);
      font-family: 'Courier New', monospace;
    }

    .paywall-testimonial {
      padding: 16px;
      border-radius: 16px;
      background: rgba(245, 197, 24, 0.05);
      border: 1px solid var(--border-subtle);
      margin-bottom: 16px;
      font-size: 14px;
      color: var(--text-primary);
      line-height: 1.6;
      font-style: italic;
    }

    .paywall-testimonial .author {
      font-style: normal;
      font-weight: 700;
      color: var(--text-secondary);
      margin-top: 8px;
    }

    .paywall-cta {
      width: 100%;
      padding: 20px 32px;
      border-radius: 50px;
      border: none;
      background: var(--primary);
      color: var(--text-primary);
      font-size: 18px;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 12px 32px rgba(29, 185, 84, 0.4);
      transition: all 0.3s ease;
      font-family: var(--font-family);
      margin-bottom: 16px;
      animation: ctaPulse 2s ease-in-out infinite;
    }

    @keyframes ctaPulse {
      0%, 100% {
        box-shadow: 0 12px 32px rgba(29, 185, 84, 0.4);
      }
      50% {
        box-shadow: 0 16px 40px rgba(29, 185, 84, 0.6);
      }
    }

    .paywall-cta:hover {
      background: var(--primary-light);
      transform: translateY(-4px) scale(1.02);
    }

    .paywall-guarantee {
      text-align: center;
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .paywall-guarantee .icon {
      display: inline-block;
      margin: 0 4px;
    }

    /* ========================================
       PROFILE LOADING
       ======================================== */
    .profile-loading-container {
      padding: 24px 0;
    }

    .circular-progress {
      text-align: center;
      margin-bottom: 24px;
    }

    .circular-progress .circle {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      transition: background 0.3s;
    }

    .circular-progress .circle-inner {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--bg-surface);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 18px;
      color: var(--text-primary);
    }

    .profile-messages {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .profile-message {
      padding: 10px 14px;
      border-radius: 12px;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary);
      animation: fadeInUp 0.4s ease-out;
      line-height: 1.4;
    }

    .profile-message.active {
      background: rgba(245, 197, 24, 0.1);
    }

    .profile-message.done {
      background: rgba(29, 185, 84, 0.1);
    }

    .profile-message.success {
      color: var(--green);
    }

    /* ========================================
       CONFETTI (CSS ONLY)
       ======================================== */
    .confetti-container {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 9998;
      overflow: hidden;
    }

    .confetti {
      position: absolute;
      width: 8px;
      height: 8px;
      opacity: 0;
      animation: confettiFall 3s ease-out forwards;
    }

    @keyframes confettiFall {
      0% {
        opacity: 1;
        transform: translateY(0) rotate(0deg);
      }
      100% {
        opacity: 0;
        transform: translateY(100vh) rotate(720deg);
      }
    }

    /* ========================================
       RESPONSIVE
       ======================================== */
    @media (max-width: 480px) {
      .logo-bar {
        padding: 10px 16px 6px;
      }

      .logo {
        font-size: 24px;
      }

      .logo-oo {
        font-size: 28px;
      }

      .card {
        border-radius: 24px 24px 0 0;
        margin: 0 8px 0 8px;
      }

      .card-content {
        padding: 20px 16px 12px 16px;
      }

      .card-action {
        padding: 12px 16px 16px 16px;
      }

      .heading {
        font-size: 19px;
        margin-bottom: 16px;
      }

      .subtitle {
        font-size: 13px;
        margin-bottom: 12px;
      }

      .chip {
        padding: 12px 14px;
        font-size: 14px;
      }

      .paywall-new-price {
        font-size: 40px;
      }

      .paywall-cta {
        font-size: 16px;
        padding: 16px 24px;
      }
    }

    @media (max-width: 375px) {
      .heading {
        font-size: 18px;
      }

      .chip {
        padding: 10px 12px;
        font-size: 13px;
        gap: 8px;
      }

      .chip .emoji {
        font-size: 16px;
      }
    }

    /* ========================================
       UTILITIES
       ======================================== */
    .hidden {
      display: none !important;
    }

    .text-center {
      text-align: center;
    }

    .mt-16 {
      margin-top: 16px;
    }

    .mb-16 {
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <!-- Particules flottantes -->
  <div class="hero-particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <!-- Confettis (injectés par JS) -->
  <div class="confetti-container" id="confetti"></div>

  <!-- Logo -->
  <div class="logo-bar">
    <div class="logo">
      <span class="logo-brav">Brav</span><span class="logo-oo">oo</span>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" id="progressBar" style="width: 0%;"></div>
  </div>

  <!-- Card principale -->
  <div class="card fade-in" id="card">
    <!-- Le contenu sera injecté par JS -->
  </div>

  <script>
    // ========================================
    // STATE
    // ========================================
    const STEPS = [
      'prenom',
      'classe',
      'moyenne',
      'matieres_fortes',
      'matieres_faibles',
      'objectif',
      'loading_quiz',
      'quiz',
      'recap_app',
      'email',
      'password',
      'loading_profile',
      'paywall'
    ];

    const CLASSES = [
      { label: 'Primaire', value: 'primaire', emoji: '🎒' },
      { label: '6ème', value: '6eme', emoji: '📚' },
      { label: '5ème', value: '5eme', emoji: '📚' },
      { label: '4ème', value: '4eme', emoji: '📚' },
      { label: '3ème', value: '3eme', emoji: '📚' },
      { label: '2nde', value: '2nde', emoji: '🎓' },
      { label: '1ère', value: '1ere', emoji: '🎓' },
      { label: 'Terminale', value: 'terminale', emoji: '🎓' },
      { label: 'BTS', value: 'bts', emoji: '💼' },
      { label: 'Prépa concours', value: 'prepa', emoji: '🏆' },
      { label: 'Code de la route', value: 'code', emoji: '🚗' },
      { label: 'Langues', value: 'langues', emoji: '🌍' },
      { label: 'Orthographe', value: 'orthographe', emoji: '✍️' }
    ];

    const SUBJECTS = [
      { key: 'mathematiques', label: 'Mathématiques', emoji: '📐' },
      { key: 'francais', label: 'Français', emoji: '📖' },
      { key: 'histoire_geo', label: 'Histoire-Géo', emoji: '🌍' },
      { key: 'sciences', label: 'Sciences', emoji: '🔬' },
      { key: 'anglais', label: 'Anglais', emoji: '🇬🇧' },
      { key: 'espagnol', label: 'Espagnol', emoji: '🇪🇸' },
      { key: 'physique', label: 'Physique', emoji: '⚛️' },
      { key: 'svt', label: 'SVT', emoji: '🧬' },
      { key: 'philo', label: 'Philosophie', emoji: '🤔' },
      { key: 'eco', label: 'Économie', emoji: '💰' },
      { key: 'arts', label: 'Arts', emoji: '🎨' },
      { key: 'musique', label: 'Musique', emoji: '🎵' },
      { key: 'eps', label: 'EPS', emoji: '🏃' }
    ];

    const ALL_QUIZ_QUESTIONS = {
      primaire: [
        {
          id: 'p1',
          subject: 'Mathématiques',
          prompt: 'Combien font 7 × 8 ?',
          choices: ['54', '56', '58', '64'],
          correctAnswerIndex: 1,
          explanation: 'La table de 7 : 7 × 8 = 56.'
        },
        {
          id: 'p2',
          subject: 'Français',
          prompt: 'Quel est le pluriel de "cheval" ?',
          choices: ['chevals', 'chevaux', 'chevaus', 'chevales'],
          correctAnswerIndex: 1,
          explanation: 'Le pluriel irrégulier de "cheval" est "chevaux".'
        },
        {
          id: 'p3',
          subject: 'Mathématiques',
          prompt: 'Combien font 15 + 27 ?',
          choices: ['32', '42', '52', '62'],
          correctAnswerIndex: 1,
          explanation: '15 + 27 = 42.'
        },
        {
          id: 'p4',
          subject: 'Français',
          prompt: 'Quelle est la bonne orthographe ?',
          choices: ['Il mangent', 'Ils mange', 'Ils mangent', 'Il mange'],
          correctAnswerIndex: 2,
          explanation: '"Ils mangent" : le verbe s\'accorde avec le sujet "ils" (3ème personne du pluriel).'
        },
        {
          id: 'p5',
          subject: 'Culture générale',
          prompt: 'Quelle est la capitale de la France ?',
          choices: ['Lyon', 'Marseille', 'Paris', 'Bordeaux'],
          correctAnswerIndex: 2,
          explanation: 'Paris est la capitale de la France.'
        }
      ],
      college: [
        {
          id: 'c1',
          subject: 'Mathématiques',
          prompt: 'Développe : 3(x + 2)',
          choices: ['3x + 2', '3x + 6', 'x + 6', '3x + 5'],
          correctAnswerIndex: 1,
          explanation: '3(x + 2) = 3 × x + 3 × 2 = 3x + 6.'
        },
        {
          id: 'c2',
          subject: 'Français',
          prompt: 'Quelle est la nature du mot souligné : "Je mange *rapidement*" ?',
          choices: ['Adjectif', 'Adverbe', 'Nom', 'Verbe'],
          correctAnswerIndex: 1,
          explanation: '"Rapidement" est un adverbe qui modifie le verbe "mange".'
        },
        {
          id: 'c3',
          subject: 'Histoire-Géo',
          prompt: 'En quelle année a eu lieu la prise de la Bastille ?',
          choices: ['1789', '1792', '1804', '1815'],
          correctAnswerIndex: 0,
          explanation: 'La prise de la Bastille a eu lieu le 14 juillet 1789, début de la Révolution française.'
        },
        {
          id: 'c4',
          subject: 'Sciences',
          prompt: 'Quelle est la formule de l\'eau ?',
          choices: ['H2O', 'CO2', 'O2', 'H2O2'],
          correctAnswerIndex: 0,
          explanation: 'L\'eau est composée de 2 atomes d\'hydrogène et 1 atome d\'oxygène : H2O.'
        },
        {
          id: 'c5',
          subject: 'Mathématiques',
          prompt: 'Combien vaut 25% de 80 ?',
          choices: ['15', '20', '25', '30'],
          correctAnswerIndex: 1,
          explanation: '25% de 80 = 0,25 × 80 = 20.'
        },
        {
          id: 'c6',
          subject: 'Français',
          prompt: 'Conjugue "avoir" à l\'imparfait, 1ère personne du singulier :',
          choices: ['J\'ai', 'J\'avais', 'J\'eus', 'J\'aurai'],
          correctAnswerIndex: 1,
          explanation: 'À l\'imparfait, "avoir" à la 1ère personne du singulier = j\'avais.'
        },
        {
          id: 'c7',
          subject: 'Anglais',
          prompt: 'Comment dit-on "Je suis étudiant" en anglais ?',
          choices: ['I am student', 'I is a student', 'I am a student', 'I are student'],
          correctAnswerIndex: 2,
          explanation: '"I am a student" : on utilise l\'article "a" devant "student".'
        },
        {
          id: 'c8',
          subject: 'Mathématiques',
          prompt: 'Résous : 2x + 5 = 15',
          choices: ['x = 5', 'x = 10', 'x = 7.5', 'x = 20'],
          correctAnswerIndex: 0,
          explanation: '2x + 5 = 15 → 2x = 10 → x = 5.'
        }
      ],
      lycee: [
        {
          id: 'l1',
          subject: 'Mathématiques',
          prompt: 'Quelle est la dérivée de x² ?',
          choices: ['x', '2x', 'x²', '2x²'],
          correctAnswerIndex: 1,
          explanation: 'La dérivée de x² est 2x (règle : (xⁿ)\' = n·xⁿ⁻¹).'
        },
        {
          id: 'l2',
          subject: 'Français',
          prompt: 'Qui a écrit "Les Misérables" ?',
          choices: ['Balzac', 'Hugo', 'Zola', 'Flaubert'],
          correctAnswerIndex: 1,
          explanation: 'Victor Hugo a écrit "Les Misérables" en 1862.'
        },
        {
          id: 'l3',
          subject: 'Physique',
          prompt: 'Quelle est l\'unité de la force ?',
          choices: ['Joule', 'Newton', 'Watt', 'Pascal'],
          correctAnswerIndex: 1,
          explanation: 'Le Newton (N) est l\'unité de force dans le système international.'
        },
        {
          id: 'l4',
          subject: 'Philosophie',
          prompt: 'Qui a dit "Je pense donc je suis" ?',
          choices: ['Platon', 'Descartes', 'Kant', 'Nietzsche'],
          correctAnswerIndex: 1,
          explanation: 'René Descartes a formulé cette phrase célèbre dans le "Discours de la méthode".'
        },
        {
          id: 'l5',
          subject: 'Mathématiques',
          prompt: 'Combien vaut cos(0) ?',
          choices: ['0', '1', '-1', '0.5'],
          correctAnswerIndex: 1,
          explanation: 'cos(0) = 1 (valeur remarquable du cercle trigonométrique).'
        },
        {
          id: 'l6',
          subject: 'Histoire',
          prompt: 'En quelle année a débuté la Première Guerre mondiale ?',
          choices: ['1914', '1918', '1939', '1945'],
          correctAnswerIndex: 0,
          explanation: 'La Première Guerre mondiale a débuté en 1914 et s\'est terminée en 1918.'
        },
        {
          id: 'l7',
          subject: 'SVT',
          prompt: 'Combien de chromosomes possède une cellule humaine normale ?',
          choices: ['23', '46', '48', '92'],
          correctAnswerIndex: 1,
          explanation: 'Une cellule humaine normale possède 46 chromosomes (23 paires).'
        },
        {
          id: 'l8',
          subject: 'Anglais',
          prompt: 'Comment dit-on "Je l\'ai déjà vu" en anglais ?',
          choices: ['I already see him', 'I have already seen him', 'I already saw him', 'I did already see him'],
          correctAnswerIndex: 1,
          explanation: 'On utilise le present perfect : "I have already seen him".'
        }
      ],
      superieur: [
        {
          id: 's1',
          subject: 'Mathématiques',
          prompt: 'Quelle est la limite de (1 + 1/n)ⁿ quand n tend vers l\'infini ?',
          choices: ['0', '1', 'e', '+∞'],
          correctAnswerIndex: 2,
          explanation: 'Cette limite définit le nombre e ≈ 2,718.'
        },
        {
          id: 's2',
          subject: 'Économie',
          prompt: 'Qu\'est-ce que le PIB ?',
          choices: ['Produit Intérieur Brut', 'Prix Indicatif de Base', 'Pourcentage d\'Inflation Bancaire', 'Placement Immobilier Boursier'],
          correctAnswerIndex: 0,
          explanation: 'Le PIB (Produit Intérieur Brut) mesure la richesse créée dans un pays.'
        },
        {
          id: 's3',
          subject: 'Informatique',
          prompt: 'Quelle est la complexité moyenne d\'un tri rapide (quicksort) ?',
          choices: ['O(n)', 'O(n log n)', 'O(n²)', 'O(log n)'],
          correctAnswerIndex: 1,
          explanation: 'La complexité moyenne du quicksort est O(n log n).'
        },
        {
          id: 's4',
          subject: 'Droit',
          prompt: 'Quelle est la durée maximale du CDI en France ?',
          choices: ['2 ans', '5 ans', 'Indéterminée', '10 ans'],
          correctAnswerIndex: 2,
          explanation: 'Le CDI (Contrat à Durée Indéterminée) n\'a pas de durée maximale.'
        },
        {
          id: 's5',
          subject: 'Physique',
          prompt: 'Quelle est la vitesse de la lumière dans le vide ?',
          choices: ['300 000 km/s', '3 000 km/s', '30 000 km/s', '300 km/s'],
          correctAnswerIndex: 0,
          explanation: 'La vitesse de la lumière dans le vide est d\'environ 300 000 km/s (299 792 458 m/s exactement).'
        }
      ]
    };

    function getQuizQuestions() {
      const classe = state.classe;
      let pool = [];

      if (classe === 'primaire') {
        pool = ALL_QUIZ_QUESTIONS.primaire;
      } else if (['6eme', '5eme', '4eme', '3eme'].includes(classe)) {
        pool = ALL_QUIZ_QUESTIONS.college;
      } else if (['2nde', '1ere', 'terminale'].includes(classe)) {
        pool = ALL_QUIZ_QUESTIONS.lycee;
      } else {
        pool = ALL_QUIZ_QUESTIONS.superieur;
      }

      // Sélectionner 6-8 questions aléatoires
      const count = Math.floor(Math.random() * 3) + 6; // 6, 7 ou 8
      const shuffled = pool.sort(() => Math.random() - 0.5);
      return shuffled.slice(0, Math.min(count, pool.length));
    }

    let currentStepIndex = 0;
    let state = {
      prenom: '',
      classe: '',
      moyenne: null,
      matieresFortes: [],
      matieresFaibles: [],
      objectif: null,
      quizAnswers: {},
      email: '',
      password: ''
    };

    // ========================================
    // NAVIGATION
    // ========================================
    function goToStep(index) {
      const card = document.getElementById('card');
      card.classList.remove('fade-in');
      card.classList.add('fade-out');

      setTimeout(() => {
        currentStepIndex = index;
        updateProgress();
        renderStep();
        card.classList.remove('fade-out');
        card.classList.add('fade-in');
      }, 250);
    }

    function goNext() {
      if (currentStepIndex < STEPS.length - 1) {
        goToStep(currentStepIndex + 1);
      }
    }

    function updateProgress() {
      const percent = ((currentStepIndex + 1) / STEPS.length) * 100;
      document.getElementById('progressBar').style.width = percent + '%';
    }

    // ========================================
    // RENDER
    // ========================================
    function renderStep() {
      const step = STEPS[currentStepIndex];
      const card = document.getElementById('card');

      switch (step) {
        case 'prenom':
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 1/7</div>
              <h2 class="heading">Comment tu t'appelles ?</h2>
              <input type="text" class="input" id="prenomInput" placeholder="Ton prénom" autofocus>
            </div>
            <div class="card-action">
              <button class="btn" id="continueBtn" disabled>Continuer</button>
            </div>
          `;
          const prenomInput = document.getElementById('prenomInput');
          const continueBtn = document.getElementById('continueBtn');
          prenomInput.value = state.prenom;
          prenomInput.addEventListener('input', (e) => {
            state.prenom = e.target.value.trim();
            continueBtn.disabled = !state.prenom;
          });
          prenomInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && state.prenom) {
              showConfetti();
              goNext();
            }
          });
          continueBtn.addEventListener('click', () => {
            showConfetti();
            goNext();
          });
          if (state.prenom) continueBtn.disabled = false;
          break;

        case 'classe':
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 2/7</div>
              <h2 class="heading">Salut ${state.prenom} ! Tu prépares quoi ?</h2>
              <div class="chips-list" id="classeList"></div>
            </div>
          `;
          const classeList = document.getElementById('classeList');
          CLASSES.forEach(c => {
            const chip = document.createElement('div');
            chip.className = 'chip' + (state.classe === c.value ? ' selected' : '');
            chip.innerHTML = `<span class="emoji">${c.emoji}</span><span>${c.label}</span>`;
            chip.addEventListener('click', () => {
              state.classe = c.value;
              setTimeout(goNext, 300);
            });
            classeList.appendChild(chip);
          });
          break;

        case 'moyenne':
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 3/7</div>
              <h2 class="heading">Quelle est ta moyenne générale à peu près ?</h2>
              <p class="subtitle">Pas besoin d'être précis, une estimation suffit !</p>
              <div class="input-wrapper">
                <input type="text" inputmode="decimal" class="input" id="moyenneInput" placeholder="Ex: 12.5" autofocus>
                <span class="input-suffix">/ 20</span>
              </div>
            </div>
            <div class="card-action">
              <button class="btn" id="continueBtn" disabled>Continuer</button>
            </div>
          `;
          const moyenneInput = document.getElementById('moyenneInput');
          const continueMoyenneBtn = document.getElementById('continueBtn');
          moyenneInput.addEventListener('input', (e) => {
            const val = e.target.value.replace(',', '.');
            const num = parseFloat(val);
            if (!isNaN(num) && num >= 0 && num <= 20) {
              state.moyenne = Math.round(num * 10) / 10;
              continueMoyenneBtn.disabled = false;
            } else {
              state.moyenne = null;
              continueMoyenneBtn.disabled = true;
            }
          });
          moyenneInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && state.moyenne !== null) goNext();
          });
          continueMoyenneBtn.addEventListener('click', goNext);
          break;

        case 'matieres_fortes':
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 4/7</div>
              <h2 class="heading">Dans quelles matières tu te sens déjà à l'aise ?</h2>
              <p class="subtitle">Tu peux en sélectionner aucune si tu le souhaites</p>
              <div class="chips-list" id="matieresFortesList"></div>
            </div>
            <div class="card-action">
              <button class="btn" id="continueBtn">Continuer</button>
            </div>
          `;
          const matieresFortesList = document.getElementById('matieresFortesList');
          SUBJECTS.forEach(s => {
            const chip = document.createElement('div');
            const selected = state.matieresFortes.includes(s.key);
            chip.className = 'chip' + (selected ? ' selected' : '');
            chip.innerHTML = `<span class="emoji">${s.emoji}</span><span>${s.label}</span>${selected ? '<span class="checkmark">✓</span>' : ''}`;
            chip.addEventListener('click', () => {
              if (state.matieresFortes.includes(s.key)) {
                state.matieresFortes = state.matieresFortes.filter(k => k !== s.key);
              } else {
                state.matieresFortes.push(s.key);
              }
              renderStep();
            });
            matieresFortesList.appendChild(chip);
          });
          document.getElementById('continueBtn').addEventListener('click', goNext);
          break;

        case 'matieres_faibles':
          const availableSubjects = SUBJECTS.filter(s => !state.matieresFortes.includes(s.key));
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 5/7</div>
              <h2 class="heading">Et celles où tu te sens moins à l'aise ?</h2>
              <p class="subtitle">C'est justement là qu'on va t'aider le plus !</p>
              <div class="chips-list" id="matieresFaiblesList"></div>
            </div>
            <div class="card-action">
              <button class="btn" id="continueBtn" disabled>Continuer</button>
            </div>
          `;
          const matieresFaiblesList = document.getElementById('matieresFaiblesList');
          availableSubjects.forEach(s => {
            const chip = document.createElement('div');
            const selected = state.matieresFaibles.includes(s.key);
            chip.className = 'chip' + (selected ? ' selected' : '');
            chip.innerHTML = `<span class="emoji">${s.emoji}</span><span>${s.label}</span>${selected ? '<span class="checkmark">✓</span>' : ''}`;
            chip.addEventListener('click', () => {
              if (state.matieresFaibles.includes(s.key)) {
                state.matieresFaibles = state.matieresFaibles.filter(k => k !== s.key);
              } else {
                state.matieresFaibles.push(s.key);
              }
              renderStep();
            });
            matieresFaiblesList.appendChild(chip);
          });
          const continueFaiblesBtn = document.getElementById('continueBtn');
          continueFaiblesBtn.disabled = state.matieresFaibles.length === 0;
          continueFaiblesBtn.addEventListener('click', goNext);
          break;

        case 'objectif':
          const options = getObjectifOptions(state.moyenne || 10);
          card.innerHTML = `
            <div class="card-content">
              <div class="step-label">Étape 6/7</div>
              <h2 class="heading">Quel est ton objectif ?</h2>
              <div style="padding: 12px 16px; border-radius: 14px; background: rgba(29, 185, 84, 0.1); margin-bottom: 16px; font-size: 14px; font-weight: 700; color: var(--primary);">
                Tu es actuellement à ${state.moyenne}/20 de moyenne
              </div>
              <div id="objectifList"></div>
            </div>
          `;
          const objectifList = document.getElementById('objectifList');
          options.forEach(opt => {
            const objCard = document.createElement('div');
            objCard.className = 'objectif-card' + (state.objectif === opt.value ? ' selected' : '');
            objCard.innerHTML = `<div class="label">${opt.label}</div><div class="value">${opt.value}/20</div>`;
            objCard.addEventListener('click', () => {
              state.objectif = opt.value;
              setTimeout(goNext, 400);
            });
            objectifList.appendChild(objCard);
          });
          break;

        case 'loading_quiz':
          card.innerHTML = `
            <div class="card-content">
              <div class="loading-container">
                <div class="spinner"></div>
                <div class="loading-msg" id="loadingMsg"></div>
              </div>
            </div>
          `;
          const messages = [
            `Ok ${state.prenom}, j'ai compris ton profil et tes objectifs !`,
            'Je suis en train de te créer un quiz personnalisé...',
            'C\'est un test de niveau qui va me permettre de m\'adapter à 100% à toi.',
            'Je vais avoir un aperçu de tes lacunes et de tes points forts...',
            `...et je vais te faire travailler de façon fun et ludique sur les choses dont tu as réellement besoin pour atteindre ${state.objectif}/20.`,
            'C\'est parti, prépare-toi !'
          ];
          let msgIndex = 0;
          document.getElementById('loadingMsg').textContent = messages[msgIndex];
          
          // Générer les questions du quiz
          state.quizQuestions = getQuizQuestions();
          
          const interval = setInterval(() => {
            msgIndex++;
            if (msgIndex >= messages.length) {
              clearInterval(interval);
              setTimeout(goNext, 1200);
            } else {
              document.getElementById('loadingMsg').textContent = messages[msgIndex];
            }
          }, 2200);
          break;

        case 'quiz':
          renderQuiz();
          break;

        case 'recap_app':
          const results = getQuizResults();
          card.innerHTML = `
            <div class="text-center mb-16">
              <h2 class="heading" style="margin-bottom: 10px; font-size: 20px;">Ok, merci pour tes réponses ! 🎉</h2>
              <p style="color: var(--text-primary); font-size: 15px; line-height: 1.6; margin: 0 0 6px; font-weight: 600;">
                J'y vois un peu plus clair sur ton profil. On va commencer à travailler ensemble et on affinera un peu chaque jour pour atteindre ton objectif de <strong style="color: var(--accent);">${state.objectif}/20</strong>. Honnêtement, je pense que tu vas y arriver.
              </p>
            </div>
            <div class="recap-score">
              <div class="percent">${results.percent}%</div>
              <div class="label">${results.correct}/${results.total} bonnes réponses au diagnostic</div>
            </div>
            <div class="recap-bullets">
              <div class="recap-bullet">
                <div class="icon blue">🎯</div>
                <div class="text">
                  <div class="title">100% personnalisé</div>
                  <div class="desc">C'est moi qui vais te guider en fonction de tes forces et tes lacunes. Pas de contenu générique, tout est adapté à toi.</div>
                </div>
              </div>
              <div class="recap-bullet">
                <div class="icon yellow">😄</div>
                <div class="text">
                  <div class="title">Fun et sans stress</div>
                  <div class="desc">On va apprendre de façon ludique. Tu vas atteindre tes objectifs dans la bonne humeur, sans pression.</div>
                </div>
              </div>
              <div class="recap-bullet">
                <div class="icon green">🧠</div>
                <div class="text">
                  <div class="title">Mémoire renforcée</div>
                  <div class="desc">Ce n'est pas parce que tu es fort quelque part qu'il faut le délaisser. Je reviendrai sur les notions déjà apprises pour ancrer les connaissances.</div>
                </div>
              </div>
            </div>
            <button class="btn" id="continueBtn">Franchement génial, let's go !</button>
          `;
          document.getElementById('continueBtn').addEventListener('click', goNext);
          break;

        case 'email':
          card.innerHTML = `
            <div class="text-center mb-16">
              <div style="font-size: 40px; margin-bottom: 10px;">😊</div>
              <h2 class="heading" style="margin-bottom: 8px; font-size: 20px;">Content que ça te plaise :)</h2>
              <p class="subtitle">Avant qu'on continue j'ai besoin que tu crées un compte pour sauvegarder ta progression. Tu veux utiliser quelle adresse mail ?</p>
            </div>
            <input type="email" class="input" id="emailInput" placeholder="ton.email@exemple.com" autofocus>
            <button class="btn" id="continueBtn" disabled>Continuer</button>
          `;
          const emailInput = document.getElementById('emailInput');
          const continueEmailBtn = document.getElementById('continueBtn');
          emailInput.value = state.email;
          emailInput.addEventListener('input', (e) => {
            state.email = e.target.value.trim();
            continueEmailBtn.disabled = !state.email.includes('@');
          });
          emailInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && state.email.includes('@')) goNext();
          });
          continueEmailBtn.addEventListener('click', goNext);
          if (state.email.includes('@')) continueEmailBtn.disabled = false;
          break;

        case 'password':
          card.innerHTML = `
            <div class="text-center mb-16">
              <h2 class="heading" style="margin-bottom: 8px; font-size: 20px;">C'est tout bon !</h2>
              <p class="subtitle">Crée-toi un mot de passe, comme "Objectifbrevet" ou "Monchiencestlemeilleur", bref on te laisse choisir :)</p>
            </div>
            <input type="password" class="input" id="passwordInput" placeholder="Ton mot de passe (6 caractères min.)" autofocus>
            <button class="btn" id="continueBtn" disabled>C'est bon j'ai choisi !</button>
            <p class="text-center" style="font-size: 11px; color: var(--text-muted); margin-top: 12px;">En créant ton compte, tu acceptes nos conditions d'utilisation.</p>
          `;
          const passwordInput = document.getElementById('passwordInput');
          const continuePasswordBtn = document.getElementById('continueBtn');
          passwordInput.value = state.password;
          passwordInput.addEventListener('input', (e) => {
            state.password = e.target.value;
            continuePasswordBtn.disabled = state.password.length < 6;
          });
          passwordInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && state.password.length >= 6) goNext();
          });
          continuePasswordBtn.addEventListener('click', goNext);
          if (state.password.length >= 6) continuePasswordBtn.disabled = false;
          break;

        case 'loading_profile':
          card.innerHTML = `
            <div class="profile-loading-container">
              <div class="circular-progress">
                <div class="circle" id="progressCircle">
                  <div class="circle-inner" id="progressPercent">0%</div>
                </div>
              </div>
              <div class="profile-messages" id="profileMessages"></div>
            </div>
          `;
          const profileMessages = [
            'Création de ton profil personnalisé...',
            `${state.prenom}, ${state.classe} — Moyenne : ${state.moyenne}/20`,
            `Objectif : ${state.objectif}/20`,
            `Points forts : ${state.matieresFortes.map(k => SUBJECTS.find(s => s.key === k)?.label || k).join(', ') || 'aucun'}`,
            `Lacunes identifiées : ${state.matieresFaibles.map(k => SUBJECTS.find(s => s.key === k)?.label || k).join(', ')}`,
            'Génération de ton programme de révision...',
            'C\'est prêt ! Bienvenue dans ton espace !'
          ];
          let progress = 0;
          let msgIdx = 0;
          const messagesDiv = document.getElementById('profileMessages');
          const progressCircle = document.getElementById('progressCircle');
          const progressPercent = document.getElementById('progressPercent');

          function addMessage(msg, active = false, success = false) {
            const div = document.createElement('div');
            div.className = 'profile-message' + (active ? ' active' : ' done') + (success ? ' success' : '');
            div.textContent = msg;
            messagesDiv.appendChild(div);
          }

          addMessage(profileMessages[msgIdx], true);

          const progressInterval = setInterval(() => {
            progress++;
            progressPercent.textContent = progress + '%';
            progressCircle.style.background = `conic-gradient(var(--accent) ${progress * 3.6}deg, var(--border-subtle) 0deg)`;
            if (progress >= 100) clearInterval(progressInterval);
          }, 105);

          const msgInterval = setInterval(() => {
            messagesDiv.children[msgIdx].classList.remove('active');
            messagesDiv.children[msgIdx].classList.add('done');
            msgIdx++;
            if (msgIdx >= profileMessages.length) {
              clearInterval(msgInterval);
              setTimeout(goNext, 1500);
            } else {
              addMessage(profileMessages[msgIdx], true, msgIdx === profileMessages.length - 1);
            }
          }, 1500);
          break;

        case 'paywall':
          renderPaywall();
          break;
      }
    }

    // ========================================
    // QUIZ
    // ========================================
    let currentQuizIndex = 0;
    let selectedAnswer = null;
    let showCorrection = false;

    function renderQuiz() {
      if (currentQuizIndex >= QUIZ_QUESTIONS.length) {
        goNext();
        return;
      }

      const q = QUIZ_QUESTIONS[currentQuizIndex];
      const card = document.getElementById('card');

      card.innerHTML = `
        <div class="quiz-header">
          <div class="step-label" style="margin-bottom: 0;">Question ${currentQuizIndex + 1}/${QUIZ_QUESTIONS.length}</div>
          <div class="quiz-badge">${q.subject}</div>
        </div>
        <h2 class="heading" style="font-size: 17px;">${q.prompt}</h2>
        <div class="quiz-choices" id="quizChoices"></div>
        <div id="quizExplanation"></div>
        <div class="quiz-progress">
          <div class="quiz-progress-fill" style="width: ${((currentQuizIndex + 1) / QUIZ_QUESTIONS.length) * 100}%;"></div>
        </div>
      `;

      const choicesDiv = document.getElementById('quizChoices');
      const explanationDiv = document.getElementById('quizExplanation');

      q.choices.forEach((choice, idx) => {
        const choiceDiv = document.createElement('div');
        let className = 'quiz-choice';
        if (showCorrection) {
          if (idx === q.correctAnswerIndex) className += ' correct';
          else if (idx === selectedAnswer) className += ' wrong';
        } else if (idx === selectedAnswer) {
          className += ' selected';
        }

        choiceDiv.className = className;
        choiceDiv.innerHTML = `<span class="letter">${String.fromCharCode(65 + idx)}</span>${choice}`;

        if (!showCorrection) {
          choiceDiv.addEventListener('click', () => {
            selectedAnswer = idx;
            showCorrection = true;
            state.quizAnswers[q.id] = idx;
            renderQuiz();

            setTimeout(() => {
              showCorrection = false;
              selectedAnswer = null;
              currentQuizIndex++;
              renderQuiz();
            }, 1800);
          });
        }

        choicesDiv.appendChild(choiceDiv);
      });

      if (showCorrection && q.explanation) {
        const expDiv = document.createElement('div');
        expDiv.className = 'quiz-explanation ' + (selectedAnswer === q.correctAnswerIndex ? 'correct' : 'wrong');
        expDiv.textContent = (selectedAnswer === q.correctAnswerIndex ? 'Bien joué ! ' : 'Pas tout à fait. ') + q.explanation;
        explanationDiv.appendChild(expDiv);
      }
    }

    // ========================================
    // PAYWALL
    // ========================================
    function renderPaywall() {
      const card = document.getElementById('card');

      // Timer countdown (72h)
      const timerKey = 'bravoo_paywall_timer';
      let endTime = localStorage.getItem(timerKey);
      if (!endTime) {
        endTime = Date.now() + 72 * 60 * 60 * 1000;
        localStorage.setItem(timerKey, endTime);
      }

      // Places restantes (7-23)
      const placesKey = 'bravoo_paywall_places';
      let places = localStorage.getItem(placesKey);
      if (!places) {
        places = Math.floor(Math.random() * 17) + 7;
        localStorage.setItem(placesKey, places);
      }

      card.innerHTML = `
        <div class="paywall-hero">
          <div class="emoji">🎉</div>
          <h2 class="title">${state.prenom}, ton espace est prêt !</h2>
          <p class="subtitle">On a hâte de t'accompagner vers la réussite !</p>
        </div>

        <div class="paywall-summary">
          <strong>${state.prenom}</strong> • ${state.classe} • Moyenne actuelle : <strong>${state.moyenne}/20</strong><br>
          Objectif : <strong>${state.objectif}/20</strong><br>
          Matières à renforcer : <strong>${state.matieresFaibles.map(k => SUBJECTS.find(s => s.key === k)?.label || k).join(', ')}</strong>
        </div>

        <div class="paywall-features">
          <div class="paywall-feature"><span class="icon">✅</span>287 exercices adaptés à ton profil</div>
          <div class="paywall-feature"><span class="icon">🤖</span>Coaching IA illimité</div>
          <div class="paywall-feature"><span class="icon">📊</span>Suivi de progression en temps réel</div>
          <div class="paywall-feature"><span class="icon">🏆</span>Plan personnalisé pour atteindre ${state.objectif}/20</div>
        </div>

        <div class="paywall-stars">★★★★★</div>

        <div class="text-center">
          <div class="paywall-badge">🔥 OFFRE LIMITÉE</div>
        </div>

        <div class="paywall-places">
          Plus que <strong>${places} places</strong> disponibles cette semaine
        </div>

        <div class="paywall-pricing">
          <div class="paywall-old-price">12,99€/semaine</div>
          <div class="paywall-new-price">3,99€</div>
          <div style="font-size: 14px; color: var(--text-secondary); margin-bottom: 8px;">/semaine</div>
          <div class="paywall-discount">-70%</div>
        </div>

        <div class="paywall-timer">
          L'offre expire dans <div class="time" id="countdown">72:00:00</div>
        </div>

        <div class="paywall-testimonial">
          "J'ai eu mon brevet mention bien grâce à Bravoo !"
          <div class="author">— Léa, 15 ans</div>
        </div>

        <button class="paywall-cta" id="paywallCta">Accéder à mon programme →</button>

        <div class="paywall-guarantee">
          <span class="icon">✓</span> Garantie 30 jours satisfait ou remboursé<br>
          <span class="icon">🔒</span> Paiement 100% sécurisé<br>
          <span class="icon">🚫</span> Sans engagement, résilie quand tu veux
        </div>
      `;

      // Countdown timer
      function updateCountdown() {
        const now = Date.now();
        const remaining = endTime - now;
        if (remaining <= 0) {
          document.getElementById('countdown').textContent = '00:00:00';
          return;
        }
        const hours = Math.floor(remaining / (1000 * 60 * 60));
        const minutes = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((remaining % (1000 * 60)) / 1000);
        document.getElementById('countdown').textContent = 
          `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
      }
      updateCountdown();
      setInterval(updateCountdown, 1000);

      // CTA
      document.getElementById('paywallCta').addEventListener('click', () => {
        alert('Paiement en cours de configuration');
      });
    }

    // ========================================
    // HELPERS
    // ========================================
    function getObjectifOptions(moyenne) {
      if (moyenne < 8) {
        return [
          { label: 'Remonter à 10 et sécuriser le brevet', value: 10 },
          { label: 'Viser 12-13 et décrocher une mention', value: 12 },
          { label: 'Tout casser et viser 15+', value: 15 }
        ];
      }
      if (moyenne < 11) {
        return [
          { label: 'Consolider et monter à 12', value: 12 },
          { label: 'Progresser sérieusement pour atteindre 14-15', value: 14 },
          { label: 'Tout casser et viser la mention Très Bien (16+)', value: 16 }
        ];
      }
      if (moyenne < 14) {
        return [
          { label: 'Maintenir le cap et sécuriser la mention', value: Math.ceil(moyenne) + 1 },
          { label: 'S\'améliorer et viser 15-16', value: 15 },
          { label: 'Viser l\'excellence : 18+', value: 18 }
        ];
      }
      return [
        { label: 'Maintenir ton excellent niveau', value: Math.ceil(moyenne) },
        { label: 'Viser 17-18 et la mention Très Bien', value: 17 },
        { label: 'Objectif 19-20 : le sans-faute', value: 19 }
      ];
    }

    function getQuizResults() {
      let correct = 0;
      const total = QUIZ_QUESTIONS.length;
      QUIZ_QUESTIONS.forEach(q => {
        if (state.quizAnswers[q.id] === q.correctAnswerIndex) correct++;
      });
      return { correct, total, percent: Math.round((correct / total) * 100) };
    }

    function showConfetti() {
      const container = document.getElementById('confetti');
      container.innerHTML = '';
      const colors = ['#1DB954', '#F5C518', '#1ED760', '#FF6B6B'];
      for (let i = 0; i < 30; i++) {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        confetti.style.left = Math.random() * 100 + '%';
        confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDelay = Math.random() * 0.5 + 's';
        container.appendChild(confetti);
      }
      setTimeout(() => {
        container.innerHTML = '';
      }, 3000);
    }

    // ========================================
    // INIT
    // ========================================
    updateProgress();
    renderStep();
  </script>
</body>
</html>
